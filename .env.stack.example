# Vercel stack — maps dashboard variable names to runtime behavior
# Copy missing keys into Vercel → Settings → Environment Variables

# CRM (required for lead forms)
FOLLOW_UP_BOSS_API_KEY=
FOLLOW_UP_BOSS_BASE_URL=https://api.followupboss.com/v1
FOLLOW_UP_BOSS_AGENT_ID=
# Legacy aliases still supported: FUB_API_KEY, FUB_SYSTEM_KEY

# AI — widget uses /api/chat with failover order:
# 1) AI_GATEWAY_API_KEY  2) OPENROUTER_API_KEY  3) openaikey / OPENAI_API_KEY
AI_GATEWAY_API_KEY=
OPENROUTER_API_KEY=
CLAUDE_API_KEY=
openaikey=

# FUB webhooks + /api/claude/chat use CLAUDE_API_KEY (alias ANTHROPIC_API_KEY)

# Notion lead log (optional — add database ID to enable)
NOTION_TOKEN=
NOTION_LEADS_DATABASE_ID=

# Analytics & media
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=letmehelpyourealtor

# RealScout + maps
NEXT_PUBLIC_REALSCOUT_AGENT_ID=QWdlbnQtMjI1MDUw
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# SMS auto-reply (Twilio inbound webhook → /api/webhooks/sms)
SMS_AUTO_REPLY_ENABLED=false
SMS_PHONE_NUMBER=
SMS_AUTO_REPLY_MESSAGE=
TWILIO_AUTH_TOKEN=
TWILIO_ACCOUNT_SID=

# MCP / design (Cursor — not runtime)
V0_API_KEY=
Linear=

# Health check after deploy: GET /api/health/stack
